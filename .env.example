# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Recommended (Supabase publishable key, format sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Legacy JWT anon key (still supported if publishable is unset)
# VITE_SUPABASE_ANON_KEY=your_anon_jwt_here

# Local Playwright / manual E2E only: fake signed-in session (never enable in production builds you ship)
# Playwright forces VITE_E2E_AUTH=0 when it starts Vite for `npm run test:e2e` (your .env.local value is ignored for that process).
# VITE_E2E_AUTH=1

# Note: Supabase may reject signups for some domains (e.g. example.com). Use a normal-looking address for real auth tests.

# --- Google OAuth (configure in dashboards; nothing to paste here) ---
# Google Cloud Console → OAuth 2.0 Client (Web) → Authorized redirect URI MUST be:
#   https://<YOUR_PROJECT_REF>.supabase.co/auth/v1/callback
# Supabase → Authentication → Providers → Google: paste Client ID + Client Secret, enable.
# Supabase → URL Configuration → Redirect URLs: include your app URL, e.g.
#   https://<your-github-user>.github.io/GraduationProject/
#   (same value as getAuthRedirectUrl() / Site URL for production)
